<pre class="language-vb"><code class="language-vb is-loaded"><span class="token keyword">Dim</span> adapter <span class="token keyword">As</span> <span class="token keyword">New</span> SqlDataAdapter<span class="token punctuation">(</span><span class="token string">"SELECT * FROM Employees"</span><span class="token punctuation">,</span> conn<span class="token punctuation">)</span>
